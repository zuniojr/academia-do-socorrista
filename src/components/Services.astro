---
const services = [
  {
    title: 'Chaveiro Residencial',
    description: 'Abertura de portas, instalação de fechaduras e troca de segredos em residências.',
    image: 'https://images.unsplash.com/photo-1558002038-1055907df827?q=80&w=800&auto=format&fit=crop'
  },
  {
    title: 'Chaveiro Automotivo',
    description: 'Chaves codificadas, abertura de veículos e conserto de ignição.',
    image: 'https://images.unsplash.com/photo-1590674880581-26ec07e1e863?q=80&w=800&auto=format&fit=crop'
  },
  {
    title: 'Fechaduras Digitais',
    description: 'Venda e instalação de fechaduras eletrônicas com senha e biometria.',
    image: 'https://images.unsplash.com/photo-1582139329536-e7284fece509?q=80&w=800&auto=format&fit=crop'
  },
  {
    title: 'Troca de Segredo',
    description: 'Troque o segredo de suas fechaduras sem precisar trocar a fechadura inteira.',
    image: 'https://images.unsplash.com/photo-1582139329536-e7284fece509?q=80&w=800&auto=format&fit=crop'
  }
];
---

<section id="servicos" class="services-section">
	<div class="container text-center">
		<h2>Nossos Principais Serviços</h2>
		<p class="subtitle">Oferecemos soluções completas em segurança para sua casa ou empresa.</p>
		
		<div class="services-grid">
			{services.map(service => (
				<div class="service-card">
					<img src={service.image} alt={service.title} />
					<div class="card-content">
						<h3>{service.title}</h3>
						<p>{service.description}</p>
						<a href="#" class="read-more">Saiba Mais →</a>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.services-section {
		padding: 100px 0;
		background-color: var(--gray);
	}
	.text-center {
		text-align: center;
	}
	h2 {
		font-size: 2.5rem;
		margin-bottom: 10px;
		color: var(--dark);
	}
	.subtitle {
		color: #666;
		margin-bottom: 60px;
		font-size: 1.1rem;
	}
	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 30px;
	}
	.service-card {
		background: var(--light);
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 5px 15px rgba(0,0,0,0.05);
		transition: all 0.3s ease;
		text-align: left;
	}
	.service-card:hover {
		transform: translateY(-10px);
		box-shadow: 0 10px 25px rgba(0,0,0,0.1);
	}
	.service-card img {
		width: 100%;
		height: 200px;
		object-fit: cover;
	}
	.card-content {
		padding: 25px;
	}
	.card-content h3 {
		font-size: 1.5rem;
		margin-bottom: 15px;
		color: var(--dark);
	}
	.card-content p {
		color: #666;
		margin-bottom: 20px;
		font-size: 0.95rem;
	}
	.read-more {
		color: var(--primary-dark);
		text-decoration: none;
		font-weight: 700;
		text-transform: uppercase;
		font-size: 13px;
	}
</style>
