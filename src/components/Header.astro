</header>

<style>
	.main-header {
		width: 100%;
		z-index: 1000;
		position: relative;
		font-family: 'Arial', sans-serif;
	}
	
	/* Top Bar */
	.top-bar {
		background-color: #0b0b0b;
		color: #ffffff;
		padding: 10px 0;
		font-size: 13px;
	}
	.top-bar-inner {
		display: flex;
		justify-content: center;
		align-items: center;
		flex-wrap: wrap;
		gap: 0;
	}
	.top-item {
		display: flex;
		align-items: center;
		padding: 0 15px;
	}
	.separator {
		border-right: 1px solid #333;
	}
	.top-item svg {
		margin-right: 8px;
	}

	/* Main Header */
	.nav-container {
		background-color: #ffffff;
		box-shadow: 0 4px 10px rgba(0,0,0,0.05);
		padding: 20px 0;
	}
	.header-main {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	/* Left Contact Area */
	.contact-area {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}
	.contact-line {
		display: flex;
		align-items: center;
		color: #1a1a1a;
		font-size: 16px;
	}
	.contact-line svg {
		margin-right: 10px;
	}

	/* Navigation */
	.main-nav ul {
		list-style: none;
		display: flex;
		margin: 0;
		padding: 0;
		gap: 25px;
	}
	.main-nav a {
		text-decoration: none;
		color: #1a1a1a;
		font-size: 15px;
		transition: color 0.3s;
		display: flex;
		align-items: center;
	}
	.main-nav a:hover {
		color: var(--primary);
	}
	.arrow {
		font-size: 10px;
		margin-left: 5px;
	}

	/* CTA Area */
	.cta-area {
		display: flex;
		align-items: center;
		border-left: 1px solid #eaeaea;
		padding-left: 20px;
	}
	.cta-icon {
		margin-right: 15px;
	}
	.cta-text {
		display: flex;
		flex-direction: column;
	}
	.cta-title {
		font-size: 16px;
		color: #1a1a1a;
	}
	.cta-phone {
		font-size: 15px;
		color: #777;
		margin-top: 2px;
	}

	@media (max-width: 992px) {
		.header-main {
			flex-direction: column;
			gap: 20px;
			text-align: center;
		}
		.top-item {
			margin-bottom: 5px;
			padding: 0 10px;
		}
		.separator {
			border-right: none;
		}
		.cta-area {
			border-left: none;
			padding-left: 0;
			justify-content: center;
		}
	}
</style>
