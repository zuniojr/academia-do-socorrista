---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Chaveiro Residencial 24 Horas - Atendimento rápido e profissional em toda a região. Especialistas em abertura de portas, troca de segredos e chaves automotivas." } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Roboto:wght@300;400;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
		<style is:global>
			:root {
				--primary: #FDC900;
				--primary-dark: #e5b600;
				--dark: #1A1A1A;
				--light: #FFFFFF;
				--gray: #F4F4F4;
				--text: #333333;
			}
			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}
			html {
				font-family: 'Roboto', sans-serif;
				background: var(--light);
				color: var(--text);
				scroll-behavior: smooth;
			}
			h1, h2, h3, h4, h5, h6 {
				font-family: 'Montserrat', sans-serif;
				font-weight: 700;
			}
			body {
				line-height: 1.6;
			}
			.container {
				max-width: 1200px;
				margin: 0 auto;
				padding: 0 20px;
			}
			.btn {
				display: inline-block;
				padding: 12px 24px;
				border-radius: 4px;
				font-weight: 700;
				text-decoration: none;
				transition: all 0.3s ease;
				text-align: center;
				cursor: pointer;
				border: none;
			}
			.btn-primary {
				background-color: var(--primary);
				color: var(--dark);
			}
			.btn-primary:hover {
				background-color: var(--primary-dark);
				transform: translateY(-2px);
			}
			.btn-dark {
				background-color: var(--dark);
				color: var(--primary);
			}
			.btn-dark:hover {
				background-color: #333;
			}
		</style>
	</body>
</html>
