---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Trabalhe Conosco | Academia do Socorrista";
const description = "Quer saber se tem uma vaguinha por aqui? Faça parte do time da Academia do Socorrista.";
---

<Layout title={title} description={description}>
	<Header />
	<main>
		<section class="page-hero">
			<div class="container animate-fade">
				<h1>Trabalhe <span class="text-gradient">Conosco</span></h1>
				<p>Quer saber se tem uma vaguinha por aqui?</p>
			</div>
		</section>

		<section class="career-section">
			<div class="container text-center">
				<div class="glass-card career-card animate-fade">
					<div class="career-icon">👋</div>
					<h2>Faça parte do time</h2>
					<p>Nosso ambiente é pautado pela alta performance e pelo compromisso em salvar vidas. Se você se identifica com nossa missão e quer transformar a educação em emergências no Brasil, clique no botão abaixo.</p>
					
					<div class="apply-cta">
						<a href="https://api.whatsapp.com/send?phone=5547996372129&text=Tem%20uma%20vaga%20ai%3F" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
							QUERO FAZER PARTE
						</a>
						<p class="cta-helper">Fale direto conosco pelo WhatsApp</p>
					</div>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.page-hero {
		padding: 150px 0 80px;
		background: var(--dark-surface);
		text-align: center;
		border-bottom: 1px solid var(--glass-border);
	}

	.page-hero h1 {
		font-size: 3.5rem;
		margin-bottom: 20px;
	}

	.page-hero p {
		font-size: 1.1rem;
		color: var(--text-muted);
		max-width: 600px;
		margin: 0 auto;
	}

	.career-section {
		padding: 100px 0 150px;
	}

	.career-card {
		padding: 80px 60px;
		max-width: 700px;
		margin: 0 auto;
	}

	.career-icon {
		font-size: 4rem;
		margin-bottom: 20px;
	}

	h2 {
		color: #fff;
		margin-bottom: 25px;
		font-size: 2.2rem;
	}

	p {
		color: var(--text-muted);
		line-height: 1.8;
		margin-bottom: 40px;
		font-size: 1.15rem;
	}

	.apply-cta {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 15px;
	}

	.btn {
		display: inline-block;
		padding: 20px 50px;
		border-radius: 100px;
		text-decoration: none;
		font-weight: 800;
		font-size: 1.2rem;
		transition: var(--transition);
		background: var(--primary);
		color: white;
		box-shadow: 0 10px 30px var(--primary-glow);
	}

	.btn:hover {
		transform: translateY(-5px);
		box-shadow: 0 15px 40px var(--primary-glow);
	}

	.cta-helper {
		font-size: 0.9rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--text-muted);
		margin-top: 10px;
	}

	@media (max-width: 768px) {
		.page-hero h1 { font-size: 3rem; }
		.career-card { padding: 60px 25px; }
	}
</style>
