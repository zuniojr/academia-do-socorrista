---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Cursos | Academia do Socorrista";
const description = "Conheça nossos treinamentos completos: avaliação de cena, controle de hemorragias, manejo de vias aéreas e tratamento de choque.";

const allServices = [
  {
    title: 'Avaliação de Cena e Segurança',
    description: 'Protocolos rigorosos para garantir a integridade da equipe e das vítimas antes de qualquer intervenção médica de risco.',
    features: ['Análise de riscos', 'Comunicação Tática', 'Isolamento da área', 'Triagem inicial'],
    icon: '🛡️',
    image: 'https://images.unsplash.com/photo-1583324113626-70df0f4deaab?q=80&w=800&auto=format&fit=crop'
  },
  {
    title: 'Controle de Hemorragias',
    description: 'Aprenda os mais recentes protocolos baseados no PHTLS e TCCC para controle agressivo de hemorragias massivas.',
    features: ['Uso correto do torniquete', 'Preenchimento de feridas (Wound Packing)', 'Curativos compressivos', 'Hemostáticos'],
    icon: '🩸',
    image: 'https://images.unsplash.com/photo-1579684385127-1ef15d508118?q=80&w=800&auto=format&fit=crop'
  },
  {
    title: 'Manejo de Vias Aéreas',
    description: 'Domine as técnicas fundamentais e avançadas para manutenção da via aérea fluida em pacientes traumatizados.',
    features: ['Manobras manuais (Jaw Thrust)', 'Cânulas Orofaringeas e Nasofaringeas', 'Manejo com Supraglóticos', 'Identificação de trauma de face'],
    icon: '🫁',
    image: 'https://images.unsplash.com/photo-1516841273335-e39b37888115?q=80&w=800&auto=format&fit=crop'
  },
  {
    title: 'Tratamento de Choque',
    description: 'Treinamento intensivo na identificação e intervenção de quadros de choque hipovolêmico sistêmico.',
    features: ['Identificação dos sinais vitais', 'Prevenção de Hipotermia', 'Reposicionamentos práticos', 'Estabilização contínua'],
    icon: '⚕️',
    image: 'https://images.unsplash.com/photo-1542884748-2b87b36c6b90?q=80&w=800&auto=format&fit=crop'
  }
];
---

<Layout title={title} description={description}>
	<Header />
	<main>
		<section class="page-hero">
			<div class="container animate-fade">
				<span class="section-badge">Treinamento Especializado</span>
				<h1>Nossos <span class="text-gradient">Cursos</span></h1>
				<p>Adquira a maestria necessária para salvar vidas em cenários reais e críticos.</p>
			</div>
		</section>

		<section class="services-detail">
			<div class="container">
				{allServices.map((service, index) => (
					<div class={`service-block ${index % 2 !== 0 ? 'reverse' : ''}`}>
						<div class="service-content animate-fade">
							<div class="service-icon">{service.icon}</div>
							<h2>{service.title}</h2>
							<p>{service.description}</p>
							<ul class="feature-list">
								{service.features.map(feature => (
									<li>
										<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
										{feature}
									</li>
								))}
							</ul>
							<a href="http://bitlybr.net/virada" class="btn btn-primary">Fazer Inscrição</a>
						</div>
						<div class="service-visual animate-fade" style="animation-delay: 0.2s;">
							<img src={service.image} alt={service.title} />
						</div>
					</div>
				))}
			</div>
		</section>

		<section class="cta-banner">
			<div class="container">
				<div class="glass-card animate-fade">
					<h2>Pronto para assumir a linha de frente?</h2>
					<p>Nenhum resgate bem sucedido é sorte. Torne-se um profissional essencial e altamente capacitado, conversando com nossa equipe.</p>
					<a href="http://bitlybr.net/virada" class="btn btn-outline">Conversar com a Equipe</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.page-hero {
		padding: 200px 0 100px;
		background: var(--dark-surface);
		text-align: center;
		border-bottom: 1px solid var(--glass-border);
	}

	.page-hero h1 {
		font-size: 4rem;
		margin-bottom: 20px;
	}

	.page-hero p {
		font-size: 1.2rem;
		color: var(--text-muted);
		max-width: 600px;
		margin: 0 auto;
	}

	.services-detail {
		padding: 120px 0;
	}

	.service-block {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 100px;
		align-items: center;
		margin-bottom: 150px;
	}

	.service-block.reverse .service-content { order: 2; }
	.service-block.reverse .service-visual { order: 1; }

	.service-icon {
		font-size: 3rem;
		margin-bottom: 25px;
		display: block;
	}

	.service-content h2 {
		font-size: 2.5rem;
		margin-bottom: 20px;
	}

	.service-content p {
		font-size: 1.1rem;
		color: var(--text-muted);
		margin-bottom: 35px;
		line-height: 1.8;
	}

	.feature-list {
		list-style: none;
		margin-bottom: 40px;
		display: grid;
		gap: 15px;
	}

	.feature-list li {
		display: flex;
		align-items: center;
		gap: 12px;
		font-weight: 600;
		color: #fff;
	}

	.service-visual img {
		width: 100%;
		border-radius: 30px;
		box-shadow: 0 40px 80px rgba(0,0,0,0.5);
	}

	.cta-banner {
		padding-bottom: 150px;
	}

	.cta-banner .glass-card {
		padding: 80px 40px;
		text-align: center;
	}

	.cta-banner h2 { font-size: 2.5rem; margin-bottom: 20px; }
	.cta-banner p { color: var(--text-muted); font-size: 1.1rem; margin-bottom: 40px; max-width: 700px; margin-inline: auto; }

	@media (max-width: 992px) {
		.service-block {
			grid-template-columns: 1fr;
			gap: 60px;
			text-align: center;
		}
		.service-block.reverse .service-content { order: 1; }
		.service-block.reverse .service-visual { order: 2; }
		.feature-list { justify-content: center; text-align: left; }
		.page-hero h1 { font-size: 3rem; }
	}
</style>
