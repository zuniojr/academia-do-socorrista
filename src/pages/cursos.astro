---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Cursos | Academia do Socorrista";
const description = "Conheça os cursos de Atendimento Pré-Hospitalar, controle de hemorragias, recuperação de afogados e guarda-vidas da Academia do Socorrista.";

const cursos = [
	{
		id: "hemorragias",
		nome: "Domine o Controle de Hemorragias",
		subtitulo: "Aprenda a salvar vidas nos primeiros minutos de uma emergência",
		descricao: "Treinamento prático e intenso nos protocolos mais modernos de controle de sangramentos massivos. Domine o uso de torniquetes, curativos hemostáticos e o protocolo Stop the Bleed seguindo os padrões internacionais do PHTLS.",
		imagem: "/cursos/hemorragias.png",
		nivel: "Fundamental",
		nivelCor: "#ef4444",
		topicos: ["Uso do torniquete CAT / SOFT-T", "Wound Packing e curativos hemostáticos", "Protocolo Stop the Bleed", "Hemorragias em junções (axila e virilha)"],
		cta: "https://api.whatsapp.com/send?phone=5547996372129&text=Quero%20saber%20mais%20sobre%20o%20curso%20de%20Controle%20de%20Hemorragias",
		ctaTexto: "Quero me Inscrever"
	},
	{
		id: "afogados",
		nome: "Recuperação de Afogados",
		subtitulo: "Na Prática",
		descricao: "Treinamento especializado em resgate aquático e recuperação de afogados. Aprenda as técnicas corretas de abordagem, extração e suporte de vida para vítimas de afogamento em ambientes de water emergência.",
		imagem: "/cursos/afogados.png",
		nivel: "Intermediário",
		nivelCor: "#f59e0b",
		topicos: ["Avaliação e abordagem à vítima aquática", "Técnicas de extração segura", "RCP em ambiente aquático", "Manejo do afogado inconsciente"],
		cta: "https://api.whatsapp.com/send?phone=5547996372129&text=Quero%20saber%20mais%20sobre%20o%20curso%20de%20Recupera%C3%A7%C3%A3o%20de%20Afogados",
		ctaTexto: "Quero me Inscrever"
	},
	{
		id: "guarda-vidas",
		nome: "Trace Seu Destino",
		subtitulo: "Torne-se um Guarda-Vidas em Portugal!",
		descricao: "Uma oportunidade única de trabalhar e se especializar como guarda-vidas em Portugal. Em parceria com a Start Portugal, este programa te prepara com todo o treinamento técnico e te conecta com as oportunidades certas no mercado europeu.",
		imagem: "/cursos/guarda-vidas.png",
		nivel: "Especializado",
		nivelCor: "#8b5cf6",
		topicos: ["Treinamento técnico completo de guarda-vidas", "Certificação reconhecida em Portugal", "Orientação para visto e residência", "Conexão direta com oportunidades de emprego"],
		cta: "https://api.whatsapp.com/send?phone=5547996372129&text=Quero%20saber%20mais%20sobre%20o%20programa%20Guarda-Vidas%20em%20Portugal",
		ctaTexto: "Saiba Mais"
	}
];
---

<Layout title={title} description={description}>
	<Header />
	<main>
		<section class="page-hero">
			<div class="container animate-fade">
				<span class="section-badge">Treinamento de Elite</span>
				<h1>Nossos <span class="text-gradient">Cursos</span></h1>
				<p>Formação técnica e prática nos protocolos mais modernos de APH e Socorrismo.</p>
			</div>
		</section>

		<section class="cursos-section">
			<div class="container">
				{cursos.map((curso, index) => (
					<div class={`curso-row animate-fade ${index % 2 !== 0 ? 'reverse' : ''}`} style={`animation-delay: ${0.15 * index}s`}>
						<div class="curso-banner">
							<img src={curso.imagem} alt={curso.nome} onerror="this.style.display='none'; this.parentElement.classList.add('no-image')" />
							<div class="banner-overlay">
								<span class="nivel-tag" style={`background: ${curso.nivelCor}22; color: ${curso.nivelCor}; border-color: ${curso.nivelCor}55`}>{curso.nivel}</span>
							</div>
						</div>

						<div class="curso-content glass-card">
							<h2>{curso.nome}</h2>
							{curso.subtitulo && <p class="subtitulo">{curso.subtitulo}</p>}
							<p class="descricao">{curso.descricao}</p>

							<ul class="topicos">
								{curso.topicos.map(t => (
									<li>
										<span class="check" style={`color: ${curso.nivelCor}`}>✔</span>
										{t}
									</li>
								))}
							</ul>

							<a href={curso.cta} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-cta">
								{curso.ctaTexto} →
							</a>
						</div>
					</div>
				))}
			</div>
		</section>

		<section class="cta-section">
			<div class="container">
				<div class="cta-box glass-card animate-fade">
					<h2>Não sabe qual curso escolher?</h2>
					<p>Fale com nossa equipe pelo WhatsApp e descubra o treinamento ideal para o seu nível e objetivo profissional.</p>
					<a href="https://api.whatsapp.com/send?phone=5547996372129&text=Quero%20saber%20qual%20curso%20%C3%A9%20ideal%20para%20mim" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
						Falar com um Especialista
					</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.page-hero {
		padding: 160px 0 100px;
		background: var(--dark-surface);
		text-align: center;
		border-bottom: 1px solid var(--glass-border);
	}

	.page-hero h1 { font-size: 4rem; margin: 15px 0 20px; }
	.page-hero p { font-size: 1.2rem; color: var(--text-muted); max-width: 650px; margin: 0 auto; }

	.section-badge {
		display: inline-block;
		background: rgba(255, 94, 0, 0.1);
		color: var(--primary);
		border: 1px solid rgba(255, 94, 0, 0.3);
		padding: 8px 20px;
		border-radius: 100px;
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.cursos-section {
		padding: 100px 0;
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.cursos-section .container {
		display: flex;
		flex-direction: column;
		gap: 60px;
	}

	/* Linha de cada curso */
	.curso-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0;
		border-radius: 24px;
		overflow: hidden;
		border: 1px solid var(--glass-border);
		transition: var(--transition);
		min-height: 360px;
	}

	.curso-row:hover {
		border-color: var(--primary);
		transform: translateY(-5px);
		box-shadow: 0 30px 60px rgba(0,0,0,0.3);
	}

	/* Imagem do curso (banner) */
	.curso-banner {
		position: relative;
		overflow: hidden;
		min-height: 360px;
		background: var(--dark-card);
	}

	.curso-banner img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
		transition: transform 0.6s ease;
	}

	.curso-row:hover .curso-banner img {
		transform: scale(1.05);
	}

	.banner-overlay {
		position: absolute;
		top: 20px;
		left: 20px;
	}

	.nivel-tag {
		padding: 6px 16px;
		border-radius: 100px;
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		border: 1px solid;
		backdrop-filter: blur(8px);
	}

	/* Conteúdo do curso */
	.curso-content {
		padding: 50px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 20px;
		border: none;
		border-radius: 0;
		background: var(--dark-card);
	}

	.curso-content:hover {
		background: var(--dark-card);
		border-color: transparent;
	}

	.curso-content h2 {
		font-size: 1.9rem;
		color: #fff;
		line-height: 1.2;
	}

	.subtitulo {
		color: var(--primary);
		font-weight: 700;
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0;
	}

	.descricao {
		color: var(--text-muted);
		font-size: 1rem;
		line-height: 1.7;
	}

	.topicos {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.topicos li {
		color: var(--text-muted);
		font-size: 0.95rem;
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.check {
		font-weight: 900;
		font-size: 0.85rem;
		flex-shrink: 0;
	}

	.btn-cta {
		align-self: flex-start;
		margin-top: 10px;
	}

	/* Linha invertida (imagem à direita) */
	.reverse {
		direction: rtl;
	}

	.reverse .curso-content {
		direction: ltr;
	}

	.reverse .curso-banner {
		direction: ltr;
	}

	/* CTA final */
	.cta-section { padding-bottom: 120px; }

	.cta-box {
		padding: 80px 60px;
		text-align: center;
		max-width: 800px;
		margin: 0 auto;
	}

	.cta-box h2 { font-size: 2.5rem; margin-bottom: 20px; }
	.cta-box p { color: var(--text-muted); font-size: 1.15rem; margin-bottom: 40px; line-height: 1.7; }

	/* Banner sem imagem */
	.no-image {
		background: linear-gradient(135deg, var(--dark-card), var(--dark-surface));
		display: flex;
		align-items: center;
		justify-content: center;
	}

	@media (max-width: 992px) {
		.curso-row, .reverse {
			grid-template-columns: 1fr;
			direction: ltr;
		}

		.curso-banner { min-height: 250px; }
		.curso-content { padding: 35px; }
		.page-hero h1 { font-size: 2.8rem; }
	}

	@media (max-width: 768px) {
		.cta-box { padding: 50px 25px; }
		.cta-box h2 { font-size: 2rem; }
		.curso-content h2 { font-size: 1.5rem; }
	}
</style>
