---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "A Academia | Academia do Socorrista";
const description = "Conheça o corpo de instrutores da Academia do Socorrista. Focados em preparar você para salvar vidas.";

const team = [
  {
    name: 'Instrutor Silva',
    role: 'Especialista em Trauma',
    bio: 'Mais de 15 anos de experiência atuando na linha de frente do resgate e instruindo novos socorristas.',
    image: 'https://images.unsplash.com/photo-1579684385127-1ef15d508118?q=80&w=400&auto=format&fit=crop'
  },
  {
    name: 'Dr. Roberto Santos',
    role: 'Diretor Médico',
    bio: 'Médico emergencista e cirurgião do trauma, responsável pela validação científica dos protocolos do treinamento.',
    image: 'https://images.unsplash.com/photo-1622253692010-333f2da6031d?q=80&w=400&auto=format&fit=crop'
  },
  {
    name: 'Cap. Oliveira',
    role: 'Instrutor Master TCCC',
    bio: 'Militar e especialista em APH Tático, desenvolvendo as práticas de sobrevivência sob situações extremas.',
    image: 'https://images.unsplash.com/photo-1541881452934-8cddfc58bcdf?q=80&w=400&auto=format&fit=crop'
  }
];
---

<Layout title={title} description={description}>
	<Header />
	<main>
		<section class="page-hero">
			<div class="container animate-fade">
				<span class="section-badge">Treinamento Especializado</span>
				<h1>Nossa <span class="text-gradient">Academia</span></h1>
				<p>Conheça os instrutores responsáveis e a nossa missão de formar socorristas de elite.</p>
			</div>
		</section>

		<section class="team-grid">
			<div class="container text-center">
				<div class="team-cards">
					{team.map((member, index) => (
						<div class="glass-card team-card animate-fade" style={`animation-delay: ${0.2 * index}s`}>
							<div class="member-image-wrapper">
								<img src={member.image} alt={member.name} />
							</div>
							<h3>{member.name}</h3>
							<span class="role">{member.role}</span>
							<p>{member.bio}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="about-timeline">
			<div class="container">
				<div class="timeline-box glass-card animate-fade">
					<div class="timeline-content">
						<h2>Nossa Missão</h2>
						<p>Fundada para trazer conhecimento de ponta para profissionais da área da saúde e segurança, a **Academia do Socorrista** nasceu com o objetivo claro de salvar o maior número de vidas possível através da educação.</p>
						<p>Investimos constantemente na atualização dos nossos protocolos e simulações para garantir que nossos alunos hajam com precisão extrema nos momentos críticos.</p>
						
						<div class="values-badges">
							<div class="value-item">⭐ Salvando Vidas</div>
							<div class="value-item">⭐ Protocolos Atuais</div>
							<div class="value-item">⭐ Controle e Resiliência</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.page-hero {
		padding: 200px 0 100px;
		background: var(--dark-surface);
		text-align: center;
		border-bottom: 1px solid var(--glass-border);
	}

	.page-hero h1 {
		font-size: 4rem;
		margin-bottom: 20px;
	}

	.page-hero p {
		font-size: 1.2rem;
		color: var(--text-muted);
		max-width: 600px;
		margin: 0 auto;
	}

	.team-grid {
		padding: 120px 0;
	}

	.team-cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 30px;
	}

	.team-card {
		padding: 40px;
		text-align: center;
		transition: var(--transition);
	}

	.member-image-wrapper {
		width: 150px;
		height: 150px;
		margin: 0 auto 30px;
		border-radius: 50%;
		overflow: hidden;
		border: 4px solid var(--primary);
		box-shadow: 0 15px 30px var(--primary-glow);
	}

	.member-image-wrapper img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.team-card h3 {
		font-size: 1.6rem;
		margin-bottom: 10px;
		color: #fff;
	}

	.team-card .role {
		display: block;
		color: var(--primary);
		font-weight: 700;
		font-size: 0.9rem;
		text-transform: uppercase;
		margin-bottom: 25px;
		letter-spacing: 0.05em;
	}

	.team-card p {
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.7;
	}

	.about-timeline {
		padding: 60px 0 150px;
	}

	.timeline-box {
		padding: 80px 60px;
		max-width: 900px;
		margin: 0 auto;
	}

	.timeline-content h2 {
		font-size: 2.5rem;
		margin-bottom: 30px;
		text-align: center;
	}

	.timeline-content p {
		font-size: 1.15rem;
		color: var(--text-muted);
		line-height: 1.8;
		margin-bottom: 25px;
	}

	.values-badges {
		display: flex;
		flex-wrap: wrap;
		gap: 15px;
		margin-top: 40px;
		justify-content: center;
	}

	.value-item {
		background: rgba(255, 215, 0, 0.1);
		color: var(--primary);
		border: 1px solid var(--primary);
		padding: 10px 20px;
		border-radius: 100px;
		font-weight: 700;
		font-size: 0.9rem;
	}

	@media (max-width: 768px) {
		.page-hero h1 { font-size: 3rem; }
		.timeline-box { padding: 60px 30px; }
	}
</style>
